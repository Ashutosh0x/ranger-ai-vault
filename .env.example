# ═══════════════════════════════════════════════
# Ranger AI Vault — Environment Configuration
# ═══════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ═══ SOLANA ═══
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_CLUSTER=devnet
# Options: devnet, mainnet-beta

# ═══ KEYPAIRS ═══
# Generate with: solana-keygen new -o <path>
# NEVER commit these files to git
ADMIN_KEYPAIR_PATH=./vault/keys/admin.json
MANAGER_KEYPAIR_PATH=./vault/keys/manager.json
AGENT_KEYPAIR_PATH=./keeper/keys/agent.json

# ═══ VAULT ADDRESSES ═══
# Fill these AFTER running admin-init-vault.ts and admin-init-strategies.ts
VAULT_ADDRESS=
KAMINO_STRATEGY_ADDRESS=
DRIFT_LEND_STRATEGY_ADDRESS=
DRIFT_PERPS_STRATEGY_ADDRESS=

# ═══ API KEYS ═══
# Coinglass: https://coinglass.com/pricing (free tier: 30 req/min)
COINGLASS_API_KEY=your_coinglass_api_key

# Shared secret between signal engine and keeper (generate a strong random string)
# Example: openssl rand -hex 32
KEEPER_SECRET=your_strong_random_secret_here

# ═══ SIGNAL ENGINE ═══
SIGNAL_SERVER_URL=http://localhost:8080
SIGNAL_SERVER_PORT=8080

# ═══ ALERTS (optional) ═══
# Create a Telegram bot via @BotFather and get the token + chat ID
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══ DASHBOARD ═══
NEXT_PUBLIC_SIGNAL_URL=http://localhost:8080
NEXT_PUBLIC_VAULT_ADDRESS=

# ═══ VAULT CONFIGURATION ═══
# Deposit amount in USDC (6 decimals)
# 1000 USDC = 1000000000
DEPOSIT_AMOUNT=1000000000
KAMINO_ALLOCATION_PCT=50
DRIFT_ALLOCATION_PCT=50

# ═══ RISK PARAMETERS ═══
# These are also hardcoded in keeper/src/config.ts
# Changing here does NOT override the code — update config.ts directly
MAX_DAILY_DRAWDOWN=0.03
MAX_MONTHLY_DRAWDOWN=0.08
MAX_LEVERAGE=2.0
MAX_NET_DELTA=0.10
STOP_LOSS_PER_TRADE=-0.005
TAKE_PROFIT_PER_TRADE=0.015
