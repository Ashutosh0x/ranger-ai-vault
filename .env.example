# ============================================================
# RANGER AI VAULT — COMPLETE .env
# Copy this to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# ── CRITICAL: Requires paid plan ───────────────────────
# Get from: https://coinglass.com/pricing (starter ~$29/mo)
# Used for: Liquidation heatmap features (KEY DIFFERENTIATOR)
COINGLASS_API_KEY=

# ── Helius RPC (free tier: 100k credits/mo) ────────────
# Sign up: https://dashboard.helius.dev
HELIUS_API_KEY=
HELIUS_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY
HELIUS_WS_URL=wss://devnet.helius-rpc.com/?api-key=YOUR_KEY
# Mainnet (if you go live):
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Solana Cluster ─────────────────────────────────────
# Options: devnet, mainnet-beta
SOLANA_CLUSTER=devnet

# ── Solana Keypairs ────────────────────────────────────
# Generate with: solana-keygen new --no-passphrase -o <path>
# NEVER commit these files to git
ADMIN_KEYPAIR_PATH=./vault/keys/admin.json
MANAGER_KEYPAIR_PATH=./vault/keys/manager.json
AGENT_KEYPAIR_PATH=./keeper/keys/agent.json
ANCHOR_WALLET=./keeper/keys/agent.json

# ── Vault Addresses ────────────────────────────────────
# Fill AFTER running admin-init-vault.ts + admin-init-strategies.ts
VAULT_ADDRESS=
KAMINO_STRATEGY_ADDRESS=
ZETA_LEND_STRATEGY_ADDRESS=
ZETA_PERPS_STRATEGY_ADDRESS=

# ── Zeta Markets (no API key — uses keypair above) ───
ZETA_ENV=devnet

# ── Jupiter V6 (no API key — public endpoints) ────────
JUPITER_QUOTE_API=https://quote-api.jup.ag/v6/quote
JUPITER_SWAP_API=https://quote-api.jup.ag/v6/swap

# ── Pyth Network (no API key — public oracle) ─────────
PYTH_HERMES_URL=https://hermes.pyth.network

# ── Signal Engine ──────────────────────────────────────
SIGNAL_SERVER_URL=http://localhost:8080
SIGNAL_SERVER_PORT=8080

# Shared secret between signal engine and keeper
# Generate: openssl rand -hex 32
KEEPER_SECRET=your_strong_random_secret_here
KEEPER_ORIGIN=http://localhost:3001

# ── Dashboard ──────────────────────────────────────────
NEXT_PUBLIC_SIGNAL_URL=http://localhost:8080
NEXT_PUBLIC_VAULT_ADDRESS=
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# ── Telegram Alerter (optional) ───────────────────────
# Create bot: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Vault Configuration ───────────────────────────────
# Deposit amount in USDC (6 decimals) — 1000 USDC = 1000000000
DEPOSIT_AMOUNT=1000000000
KAMINO_ALLOCATION_PCT=50
ZETA_ALLOCATION_PCT=50

# ── Risk Parameters ───────────────────────────────────
# Also hardcoded in keeper/src/config.ts
# Update config.ts directly if changing these
MAX_DAILY_DRAWDOWN=0.03
MAX_MONTHLY_DRAWDOWN=0.08
MAX_LEVERAGE=2.0
MAX_NET_DELTA=0.10
STOP_LOSS_PER_TRADE=-0.005
TAKE_PROFIT_PER_TRADE=0.015
MAX_CONCURRENT_POSITIONS=3
KELLY_FRACTION=0.25
MIN_HEALTH_RATE=1.5
VAR_CONFIDENCE=0.95

# ── Vault Allocation Amounts (raw USDC, 6 decimals) ──
# 1000 USDC = 1000000000
DEPOSIT_AMOUNT=1000000000
KAMINO_ALLOCATION=500000000
ZETA_LEND_ALLOCATION=250000000
ZETA_PERPS_ALLOCATION=250000000

# ── Docker / Monitoring ───────────────────────────────
# Generate with: openssl rand -base64 24
GRAFANA_PASSWORD=
GITHUB_REPO=Ashutosh0x/ranger-ai-vault

# ── Dry Run Mode ──────────────────────────────────────
DRY_RUN=false
USE_SYNTHETIC_DATA=false
